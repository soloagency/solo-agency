<!doctype html>
<html>
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Solo Agency Local Collector</title>
  <style>
    body {
      width: 360px;
      margin: 0;
      padding: 14px;
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      color: #17202a;
      background: #ffffff;
    }
    h1 {
      font-size: 16px;
      margin: 0 0 10px;
    }
    label {
      display: block;
      font-size: 12px;
      font-weight: 600;
      margin-top: 10px;
    }
    input {
      width: 100%;
      box-sizing: border-box;
      border: 1px solid #d0d7de;
      border-radius: 6px;
      padding: 8px;
      font: inherit;
    }
    input[type="checkbox"] {
      width: auto;
      margin-right: 6px;
    }
    button {
      border: 0;
      border-radius: 6px;
      background: #0969da;
      color: #fff;
      padding: 9px 12px;
      font-weight: 700;
      cursor: pointer;
    }
    button.secondary {
      background: #57606a;
    }
    .row {
      display: flex;
      gap: 8px;
      margin-top: 12px;
    }
    .row button {
      flex: 1;
    }
    .status {
      border: 1px solid #d8dee4;
      border-radius: 8px;
      padding: 10px;
      background: #f6f8fa;
      font-size: 13px;
      white-space: pre-wrap;
    }
    .hint {
      color: #57606a;
      font-size: 12px;
      margin-top: 8px;
      line-height: 1.35;
    }
  </style>
</head>
<body>
  <h1>Solo Agency Local Collector</h1>
  <div id="status" class="status">Loading...</div>

  <label>
    <input id="enabled" type="checkbox">
    Enabled
  </label>

  <label for="bridgeBaseUrl">Local bridge URL</label>
  <input id="bridgeBaseUrl" type="text" value="http://127.0.0.1:17321">

  <label for="pollMinutes">Poll interval, minutes</label>
  <input id="pollMinutes" type="number" min="1" max="60" value="1">

  <label for="pollSeconds">Short poll interval while active, seconds</label>
  <input id="pollSeconds" type="number" min="5" max="60" value="5">

  <label for="minDelaySeconds">Min delay between actions, seconds</label>
  <input id="minDelaySeconds" type="number" min="5" max="20" value="5">

  <label for="maxDelaySeconds">Max delay between actions, seconds</label>
  <input id="maxDelaySeconds" type="number" min="1" max="30" value="5">

  <label for="maxSourcesPerRun">Max private sources per run</label>
  <input id="maxSourcesPerRun" type="number" min="1" max="50" value="20">

  <label for="scrollSteps">Scrolls per private source</label>
  <input id="scrollSteps" type="number" min="0" max="10" value="5">

  <label>
    <input id="closeTabsAfterCollect" type="checkbox">
    Close collector tabs after scan
  </label>

  <div class="row">
    <button id="save">Save</button>
    <button id="checkNow" class="secondary">Check now</button>
  </div>

  <p class="hint">This extension only reads visible pages from configured jobs and sends results to your local bridge. It does not ask for passwords and does not upload data to cloud services.</p>

  <script src="popup.js"></script>
</body>
</html>
