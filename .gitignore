# OS/editor noise
.DS_Store
*.swp
*.swo
.idea/
.vscode/

# Language/tool caches
__pycache__/
*.pyc
.pytest_cache/
node_modules/
.cache/
.venv/
venv/

# Local maintainer tooling
deploy-soloagency.sh

# Local runtime/data generated by installed agencies
daily-content-pipeline/
solo-agency-local-collector/
backup/
backups/

# Logs and local environment/secrets
*.log
.env
.env.local
*.pem
*.key
provider_config.local.json
**/provider_config.local.json

# Session/backup copies anywhere (git history is the backup)
*_20[2-9][0-9]-[0-9][0-9]-[0-9][0-9]_[0-9][0-9]-[0-9][0-9]-[0-9][0-9].*
*.bak

# Internal working docs — never ship to the public product repo
AUDIT_FINDINGS_*.md
*_HARDENING_PLAN.md
PROPOSED_ADDITIONS_*.md
TODO.md
handoff.md

# Build artifacts — rebuilt by deploy-soloagency.sh every run; NOT committed.
# The collector-bridge binaries zip is ~11 MB and changes each build, so committing
# it repeatedly bloated .git to ~700 MB. Distribute binaries via GitHub Releases,
# not git. (Existing tracked copies were removed with `git rm --cached`.)
solo-agency-collector/dist/

# Keep the small, content-versioned playbook/skill zip packages committed.
!playbooks/skills/*.zip
