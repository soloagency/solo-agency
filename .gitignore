# OS/editor noise
.DS_Store
*.swp
*.swo
.idea/
.vscode/

# Language/tool caches
__pycache__/
*.pyc
.pytest_cache/
node_modules/
.cache/
.venv/
venv/

# Local runtime/data generated by installed agencies
outreach-pipeline/
backup/
backups/

# Logs and local environment/secrets
*.log
.env
.env.local
.dev.vars
*.pem
*.key

# Per-client and agency secrets (never commit)
secrets/
provider_config.local.json
**/provider_config.local.json
**/sendboxes/*/token.json
**/sendboxes/*/credentials.json
**/client_secret*.json
**/google_oauth_client.json

# Keep committed zip artifacts.
!playbooks/skills/*.zip

# Session backup copies {name}_{YYYY-MM-DD}_{HH-MM-SS}.{ext} (git history is the backup)
*_20[2-9][0-9]-[0-9][0-9]-[0-9][0-9]_[0-9][0-9]-[0-9][0-9]-[0-9][0-9].*
